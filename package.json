{
  "name": "english-study-shelf",
  "version": "0.1.0",
  "private": true,
  "description": "本地英语 PDF 学习书架 / Local English PDF study shelf with selected-text AI explanations.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm:dev -w @english-study-shelf/api\" \"npm:dev -w @english-study-shelf/web\"",
    "build": "npm run build --workspaces",
    "check": "npm run guard:private && npm run check --workspaces",
    "guard:private": "node scripts/check-private-files.cjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
